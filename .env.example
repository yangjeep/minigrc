# Copy to .env for local development. All variables are optional; defaults
# match app/config.py.

# Path to the SQLite database file. Mount a persistent volume at this path
# in Docker (see README.md).
GRC_DATABASE_PATH=./data/grc.db

# Python logging level: DEBUG, INFO, WARNING, ERROR.
GRC_LOG_LEVEL=INFO

# Free-text environment label, currently only used for visibility.
GRC_APP_ENV=development
