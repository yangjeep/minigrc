# Copy to .env for local development. All variables are optional; defaults
# match app/config.py. Never commit a real .env file — it is gitignored.

# Directory holding all persistent data: grc.db, policies/, tmp/.
# In Docker this is always /data (a mounted named volume — see compose.yaml).
GRC_DATA_DIR=./data

# Override the SQLite database file path directly. Leave unset to derive it
# from GRC_DATA_DIR (GRC_DATA_DIR/grc.db).
# GRC_DATABASE_PATH=./data/grc.db

# Python logging level: DEBUG, INFO, WARNING, ERROR.
GRC_LOG_LEVEL=INFO

# Free-text environment label, currently only used for visibility.
GRC_APP_ENV=development

# Maximum accepted upload size (policy documents, CSV imports), in megabytes.
GRC_MAX_UPLOAD_MB=25

# Maximum data rows accepted in one vendor user-roster CSV import.
GRC_MAX_VENDOR_ROSTER_ROWS=5000

# How long a login session stays valid before it must be renewed.
GRC_SESSION_TTL_HOURS=168

# Set to true once the app is served over HTTPS (production). Marks the
# session and CSRF cookies Secure, so browsers withhold them over plain HTTP.
GRC_SESSION_COOKIE_SECURE=false

# --- Google OIDC login (optional) ---
# All three of these must be set for the "Sign in with Google" link to
# appear; local email/password login always remains available regardless.
# Public base URL this app is served at — used only to derive the OAuth
# redirect URI safely (never derived from the request's Host header).
# GRC_PUBLIC_BASE_URL=https://grc.example.com
# OAuth 2.0 Client ID / secret from Google Cloud Console (APIs & Services >
# Credentials > OAuth client ID > Web application). Redirect URI to
# register there: <GRC_PUBLIC_BASE_URL>/auth/google/callback
# GRC_GOOGLE_OIDC_CLIENT_ID=
# GRC_GOOGLE_OIDC_CLIENT_SECRET=
# Comma-separated Workspace domains allowed to sign in via the verified
# `hd` claim (never the email suffix alone). Empty = no domain restriction.
# GRC_GOOGLE_OIDC_ALLOWED_DOMAINS=example.com

# --- Google Drive connector (optional) ---
# Distinct OAuth client from the OIDC login above, even if pointed at the
# same Google Cloud project. Redirect URI to register in Google Cloud
# Console: <GRC_PUBLIC_BASE_URL>/connectors/google-drive/callback
# Requested scope is read-only (drive.readonly) — no write access.
# GRC_GOOGLE_DRIVE_CLIENT_ID=
# GRC_GOOGLE_DRIVE_CLIENT_SECRET=
# Symmetric key used to encrypt the stored Drive refresh token at rest.
# Required for the connector to be usable. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# GRC_ENCRYPTION_KEY=
